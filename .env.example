APP_NAME=Order_Timeline_Viewer
APP_ENV=local
APP_KEY=base64:ost5tb/Ze6jqQLDZPWGSIaf4/kL9dL4pVUYOYGy9OjA=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://ashar.xoarhigh.info

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=order_timeline_viewer
DB_USERNAME=root
DB_PASSWORD=


SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null



BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis



CACHE_STORE=database
CACHE_PREFIX=


REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"



AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false



VITE_APP_NAME="${APP_NAME}"
VITE_SHOPIFY_API_KEY="${SHOPIFY_API_KEY}"



SHOPIFY_API_VERSION="2025-04"
SHOPIFY_APP_NAME="${APP_NAME}"

SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

SHOPIFY_APPBRIDGE_ENABLED=1
SHOPIFY_BILLING_ENABLED=0
# SHOPIFY_BILLING_FREEMIUM_ENABLED=0


SHOPIFY_API_SCOPES=read_orders,write_orders,read_customers,read_products,write_products


SHOPIFY_WEBHOOK_1_TOPIC="app/uninstalled"
SHOPIFY_WEBHOOK_1_ADDRESS="${APP_URL}/webhook/app-uninstalled"

SHOPIFY_WEBHOOK_2_TOPIC="orders/create"
SHOPIFY_WEBHOOK_2_ADDRESS="${APP_URL}/webhook/orders-create"

SHOPIFY_WEBHOOK_3_TOPIC="orders/updated"
SHOPIFY_WEBHOOK_3_ADDRESS="${APP_URL}/webhook/orders-updated"

SHOPIFY_WEBHOOK_4_TOPIC="orders/paid"
SHOPIFY_WEBHOOK_4_ADDRESS="${APP_URL}/webhook/orders-paid"

SHOPIFY_WEBHOOK_5_TOPIC="orders/fulfilled"
SHOPIFY_WEBHOOK_5_ADDRESS="${APP_URL}/webhook/orders-fulfilled"

SHOPIFY_WEBHOOK_6_TOPIC="orders/cancelled"
SHOPIFY_WEBHOOK_6_ADDRESS="${APP_URL}/webhook/orders-cancelled"

SHOPIFY_WEBHOOK_7_TOPIC="orders/delete"
SHOPIFY_WEBHOOK_7_ADDRESS="${APP_URL}/webhook/orders-delete"


ORDER_SYNC_LIMIT=50
ORDER_SYNC_QUEUE=default
WEBHOOK_QUEUE=webhooks
WEBHOOK_RETRY_LIMIT=3
TIMELINE_DELAY_THRESHOLD_HOURS=24